---
layout: base.njk
title: "Overherd"
permalink: /overherd/
---
<h2 class="page-title">overherd</h2>
<ul class="collection-list">
  {% for set in collections.overherd %}
  <li>
    <a href="{{ set.url }}">{{ set.data.title }}</a>
    {% if set.data.images and set.data.images[0] %}
      {% set preview = set.data.images[0] %}
      <img class="photo-index-thumb" src="{{ preview.src }}" alt="{{ preview.alt }}" />
    {% endif %}
  </li>
  {% endfor %}
</ul>
